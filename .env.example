# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini / Vertex AI
GEMINI_API_KEY=
VERTEX_AI_LOCATION=us-central1

# Neo4j Aura
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=nexusdrift-embeddings
PINECONE_ENVIRONMENT=

# Firestore
FIRESTORE_PROJECT_ID=

# Pub/Sub Topics
PUBSUB_TOPIC_RAW_ARTIFACTS=nexusdrift-raw-artifacts
PUBSUB_TOPIC_PARSED_ENTITIES=nexusdrift-parsed-entities
PUBSUB_TOPIC_GRAPH_UPDATES=nexusdrift-graph-updates
PUBSUB_TOPIC_ALERTS=nexusdrift-alerts

# External Integrations
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Clerk Auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Ingestion
GITHUB_REPOS=
JIRA_PROJECT_KEYS=
SLACK_CHANNEL_IDS=

# Pub/Sub Subscriptions
PUBSUB_SUBSCRIPTION_GRAPH_UPDATES=nexusdrift-graph-updates-reasoning

# Reasoning
CONTRADICTION_SIMILARITY_THRESHOLD=0.75
CONTRADICTION_SEVERITY_THRESHOLD=0.3
CONTRADICTION_INTERVAL_SECONDS=900
RISK_SCORING_INTERVAL_SECONDS=1800
BIGQUERY_DATASET=nexusdrift

# Watchtower
WATCHTOWER_INTERVAL_SECONDS=3600
WATCHTOWER_MODEL=gemini-2.5-flash

# Application
API_HOST=0.0.0.0
API_PORT=8080
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://nexusdrift.vercel.app
